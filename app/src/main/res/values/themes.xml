<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- Base Application Theme (Material 3 — Dark)                             -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <style name="Theme.Breathy" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary brand color — neon green -->
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorOnPrimary">@color/text_inverse</item>
        <item name="colorPrimaryContainer">@color/accent_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/accent_primary</item>

        <!-- Secondary brand color — neon red/coral -->
        <item name="colorSecondary">@color/accent_secondary</item>
        <item name="colorOnSecondary">@color/text_inverse</item>
        <item name="colorSecondaryContainer">@color/accent_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/accent_secondary</item>

        <!-- Tertiary brand color — purple -->
        <item name="colorTertiary">@color/accent_purple</item>
        <item name="colorOnTertiary">@color/text_inverse</item>
        <item name="colorTertiaryContainer">@color/accent_purple_container</item>
        <item name="colorOnTertiaryContainer">@color/accent_purple</item>

        <!-- Background colors -->
        <item name="colorBackground">@color/bg_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/bg_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Error colors -->
        <item name="colorError">@color/semantic_error</item>
        <item name="colorOnError">@color/white</item>
        <item name="colorErrorContainer">@color/semantic_error_container</item>
        <item name="colorOnErrorContainer">@color/semantic_error</item>

        <!-- Outlines -->
        <item name="colorOutline">@color/outline</item>
        <item name="colorOutlineVariant">@color/outline_variant</item>

        <!-- Inverse -->
        <item name="colorInverseSurface">@color/text_primary</item>
        <item name="colorInverseOnSurface">@color/bg_primary</item>
        <item name="colorInversePrimary">@color/accent_primary_pressed</item>

        <!-- Surface container (M3) -->
        <item name="colorSurfaceContainerLowest">@color/bg_primary</item>
        <item name="colorSurfaceContainerLow">@color/bg_surface</item>
        <item name="colorSurfaceContainer">@color/bg_surface_variant</item>
        <item name="colorSurfaceContainerHigh">@color/bg_surface_elevated</item>
        <item name="colorSurfaceContainerHighest">@color/bg_surface_elevated</item>

        <!-- Scrim -->
        <item name="android:colorBackgroundCacheHint">@null</item>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- Status Bar & Navigation Bar                                          -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:navigationBarColor">@color/bg_surface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- Window Configuration                                                 -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowIsTranslucent">false</item>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- Typography — mapped to our custom font scale                         -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.Breathy.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.Breathy.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.Breathy.HeadlineSmall</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.Breathy.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.Breathy.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.Breathy.CaptionLarge</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.Breathy.BodyMedium</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.Breathy.CaptionLarge</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.Breathy.CaptionSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.Breathy.HeadlineSmall</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.Breathy.BodyLarge</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.Breathy.BodyMedium</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- Splash Screen Theme                                                    -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <style name="Theme.Breathy.Splash" parent="Theme.SplashScreen.IconBackground">
        <item name="windowSplashScreenBackground">@color/bg_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_notification</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/accent_primary_container</item>
        <item name="postSplashScreenTheme">@style/Theme.Breathy</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- Typography Styles                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->

    <style name="TextAppearance.Breathy.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.02</item>
        <item name="android:lineHeight">32sp</item>
    </style>

    <style name="TextAppearance.Breathy.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.01</item>
        <item name="android:lineHeight">28sp</item>
    </style>

    <style name="TextAppearance.Breathy.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineHeight">24sp</item>
    </style>

    <style name="TextAppearance.Breathy.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:lineHeight">24sp</item>
    </style>

    <style name="TextAppearance.Breathy.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:letterSpacing">0.015</item>
        <item name="android:lineHeight">20sp</item>
    </style>

    <style name="TextAppearance.Breathy.CaptionLarge" parent="TextAppearance.Material3.BodySmall">
        <item name="fontFamily">sans-serif-light</item>
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:letterSpacing">0.03</item>
        <item name="android:lineHeight">16sp</item>
    </style>

    <style name="TextAppearance.Breathy.CaptionSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="fontFamily">sans-serif-light</item>
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/text_disabled</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:lineHeight">14sp</item>
    </style>

    <style name="TextAppearance.Breathy.StatHero" parent="TextAppearance.Material3.DisplayLarge">
        <item name="fontFamily">monospace</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">48sp</item>
        <item name="android:textColor">@color/accent_primary</item>
        <item name="android:letterSpacing">-0.02</item>
        <item name="android:lineHeight">56sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Breathy.StatCard" parent="TextAppearance.Material3.DisplayMedium">
        <item name="fontFamily">monospace</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/accent_primary</item>
        <item name="android:letterSpacing">-0.01</item>
        <item name="android:lineHeight">40sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- Component Overrides                                                    -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->

    <!-- ── Buttons ──────────────────────────────────────────────────────────── -->

    <style name="Widget.Breathy.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">24dp</item>
        <item name="android:textAppearance">@style/TextAppearance.Breathy.HeadlineSmall</item>
        <item name="android:textColor">@color/text_inverse</item>
        <item name="backgroundTint">@color/accent_primary</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="Widget.Breathy.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">24dp</item>
        <item name="android:textAppearance">@style/TextAppearance.Breathy.BodyMedium</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="strokeColor">@color/text_secondary</item>
        <item name="strokeWidth">1dp</item>
        <item name="backgroundTint">@color/transparent</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="Widget.Breathy.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="cornerRadius">24dp</item>
        <item name="android:textAppearance">@style/TextAppearance.Breathy.BodyMedium</item>
        <item name="android:textColor">@color/accent_primary</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="Widget.Breathy.Button.Icon" parent="Widget.Material3.Button.Icon">
        <item name="cornerRadius">24dp</item>
        <item name="android:textColor">@color/text_inverse</item>
        <item name="backgroundTint">@color/accent_primary</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="Widget.Breathy.Button.Gradient" parent="Widget.Material3.Button">
        <item name="cornerRadius">24dp</item>
        <item name="android:textAppearance">@style/TextAppearance.Breathy.HeadlineSmall</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:minHeight">48dp</item>
        <!-- Gradient background applied programmatically via Brush in Compose -->
    </style>

    <!-- ── Cards ───────────────────────────────────────────────────────────── -->

    <style name="Widget.Breathy.Card" parent="Widget.Material3.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardBackgroundColor">@color/bg_surface</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/outline_neon</item>
        <item name="strokeWidth">1dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <style name="Widget.Breathy.Card.Elevated" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardBackgroundColor">@color/bg_surface_variant</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/outline</item>
        <item name="strokeWidth">1dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <style name="Widget.Breathy.Card.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardBackgroundColor">@color/bg_surface</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/outline_neon</item>
        <item name="strokeWidth">1dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- ── Text Fields ─────────────────────────────────────────────────────── -->

    <style name="Widget.Breathy.TextInputLayout" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="cornerRadius">12dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxBackgroundColor">@color/bg_surface_variant</item>
        <item name="boxStrokeColor">@color/accent_primary</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_disabled</item>
    </style>

    <style name="Widget.Breathy.TextInputLayout.Outlined" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="cornerRadius">12dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/outline</item>
        <item name="boxStrokeFocusedColor">@color/accent_primary</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_disabled</item>
    </style>

    <!-- ── Bottom Sheet ────────────────────────────────────────────────────── -->

    <style name="Widget.Breathy.BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="shapeAppearance">@style/ShapeAppearance.Breathy.BottomSheet</item>
        <item name="backgroundTint">@color/bg_surface</item>
    </style>

    <style name="Widget.Breathy.BottomSheet.Modal" parent="Widget.Material3.BottomSheet.Modal">
        <item name="shapeAppearance">@style/ShapeAppearance.Breathy.BottomSheet</item>
        <item name="backgroundTint">@color/bg_surface</item>
        <item name="android:backgroundTint">@color/bg_surface</item>
    </style>

    <!-- ── Navigation ──────────────────────────────────────────────────────── -->

    <style name="Widget.Breathy.NavigationBar" parent="Widget.Material3.NavigationBar">
        <item name="backgroundTint">@color/bg_surface</item>
        <item name="itemIconTint">@color/nav_item_color</item>
        <item name="itemTextColor">@color/nav_item_color</item>
        <item name="itemRippleColor">@color/accent_primary_container</item>
        <item name="android:minHeight">56dp</item>
    </style>

    <style name="Widget.Breathy.TopAppBar" parent="Widget.Material3.TopAppBar">
        <item name="titleTextColor">@color/text_primary</item>
        <item name="subtitleTextColor">@color/text_secondary</item>
        <item name="navigationIconTint">@color/text_primary</item>
        <item name="actionIconTint">@color/text_secondary</item>
    </style>

    <!-- ── Chips ───────────────────────────────────────────────────────────── -->

    <style name="Widget.Breathy.Chip" parent="Widget.Material3.Chip.Suggestion">
        <item name="chipCornerRadius">20dp</item>
        <item name="chipBackgroundColor">@color/bg_surface_variant</item>
        <item name="chipStrokeColor">@color/outline</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Widget.Breathy.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">20dp</item>
        <item name="chipBackgroundColor">@color/bg_surface_variant</item>
        <item name="checkedIconTint">@color/accent_primary</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- ── Dialog ──────────────────────────────────────────────────────────── -->

    <style name="Widget.Breathy.Dialog" parent="ThemeOverlay.Material3.Dialog">
        <item name="cornerRadius">28dp</item>
        <item name="android:background">@color/bg_surface</item>
        <item name="android:windowBackground">@color/bg_surface</item>
    </style>

    <style name="Widget.Breathy.AlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="shapeAppearance">@style/ShapeAppearance.Breathy.Dialog</item>
        <item name="android:background">@color/bg_surface</item>
    </style>

    <!-- ── Floating Action Button ──────────────────────────────────────────── -->

    <style name="Widget.Breathy.FAB" parent="Widget.Material3.FloatingActionButton">
        <item name="backgroundTint">@color/accent_orange</item>
        <item name="tint">@color/white</item>
        <item name="fabCustomSize">56dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Breathy.FAB</item>
    </style>

    <!-- ── Progress Indicator ──────────────────────────────────────────────── -->

    <style name="Widget.Breathy.LinearProgressIndicator" parent="Widget.Material3.LinearProgressIndicator">
        <item name="trackColor">@color/bg_surface_variant</item>
        <item name="indicatorColor">@color/accent_primary</item>
    </style>

    <style name="Widget.Breathy.CircularProgressIndicator" parent="Widget.Material3.CircularProgressIndicator">
        <item name="trackColor">@color/bg_surface_variant</item>
        <item name="indicatorColor">@color/accent_primary</item>
    </style>

    <!-- ── Snackbar ────────────────────────────────────────────────────────── -->

    <style name="Widget.Breathy.Snackbar" parent="Widget.Material3.Snackbar">
        <item name="backgroundTint">@color/bg_surface_elevated</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="actionTextColorAlpha">1.0</item>
    </style>

    <!-- ── Tab Row ─────────────────────────────────────────────────────────── -->

    <style name="Widget.Breathy.TabRow" parent="Widget.Material3.TabLayout">
        <item name="tabIndicatorColor">@color/accent_primary</item>
        <item name="tabTextColor">@color/text_secondary</item>
        <item name="tabSelectedTextColor">@color/text_primary</item>
        <item name="tabRippleColor">@color/accent_primary_container</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- Shape Appearances                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->

    <style name="ShapeAppearance.Breathy.Card" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.Breathy.Button" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="ShapeAppearance.Breathy.InputField" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.Breathy.Chip" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <style name="ShapeAppearance.Breathy.BottomSheet" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="ShapeAppearance.Breathy.Dialog" parent="ShapeAppearance.Material3.ExtraLargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>

    <style name="ShapeAppearance.Breathy.FAB" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="ShapeAppearance.Breathy.Avatar" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- Color Selectors                                                        -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->

</resources>
